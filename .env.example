# ──────────────────────────────────────────────────────────────────────────
# .env.example — cmfamily-piscine
#
# Copie ce fichier en .env.local pour le dev local (Vercel CLI le lit
# automatiquement avec `vercel dev`). En production, configure ces variables
# directement dans Vercel → Settings → Environment Variables.
#
# IMPORTANT : aucune vraie valeur ici. Placeholders uniquement.
# Les valeurs réelles vivent dans ~/.secrets/pool/*.env (chmod 600) et
# côté Vercel pour la prod.
# ──────────────────────────────────────────────────────────────────────────

# ─── Supabase (projet piscine-2026) ───────────────────────────────────────
# URL publique du projet Supabase. Hardcodée par défaut dans api/_supabase.js,
# n'est utile que pour override (ex: pointer un projet de test).
# Référence prod : https://dfedxlqcbrhbxrxwspru.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# Clé service_role (JWT, ~210 caractères, commence par "eyJ").
# SECRET — bypass RLS. À configurer en Sensitive côté Vercel (Production).
# Récupérable depuis Supabase Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt>

# ─── Admin endpoints (PUT/DELETE protégés) ────────────────────────────────
# Secret partagé entre l'API serverless et les scripts admin locaux.
# Header attendu côté API : x-admin-secret: <valeur>
# SECRET — à configurer côté Vercel et localement (voir PISCINE_ADMIN_SECRET).
ADMIN_SECRET=<admin_secret_aleatoire>

# ─── Scripts locaux (scripts/sync.py) ─────────────────────────────────────
# URL du site déployé, utilisée par sync.py pour pull/push.
# Défaut codé : https://cmfamily-piscine.vercel.app
PISCINE_SITE_URL=https://cmfamily-piscine.vercel.app

# Secret admin pour les opérations sync.py push / pull-comments.
# Doit correspondre exactement à ADMIN_SECRET configuré côté Vercel.
PISCINE_ADMIN_SECRET=<meme_valeur_que_ADMIN_SECRET>
